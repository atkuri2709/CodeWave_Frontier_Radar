# Frontier AI Radar - Backend
# Copy to .env and set values

# Database: local SQLite only (file stored in backend/data/)
# DATABASE_URL=sqlite+aiosqlite:///./data/radar.db

# Config file path (relative to cwd when running from backend/)
CONFIG_PATH=config/radar.yaml

# Crawling
# VERIFY_SSL=false
# DEFAULT_RATE_LIMIT_PER_DOMAIN=1.0
# MAX_PAGES_PER_DOMAIN=50
# REQUEST_TIMEOUT_SECONDS=30

# LLM summarization: set LLM_PROVIDER=claude (default) or openai; set the matching API key
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# SUMMARIZATION_MAX_TOKENS=1000

# Email (optional; digest is still generated and stored)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=radar@example.com
# EMAIL_RECIPIENTS=["you@example.com","team@example.com"]

# Storage
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=storage

# CORS (comma-separated or JSON array)
# CORS_ORIGINS=["http://localhost:3000"]

# Debug
# DEBUG=false
